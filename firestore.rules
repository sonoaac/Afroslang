rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    // Users can read and write their own document only.
    // The Cloud Function (admin SDK) bypasses these rules entirely.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Leaderboard ────────────────────────────────────────────────────────
    // Any authenticated user can read leaderboard data.
    // Only authenticated users can write their own leaderboard entry.
    match /leaderboards/{weekId}/{league}/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Deny everything else ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
